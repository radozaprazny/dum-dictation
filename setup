#!/usr/bin/env bash
# setup — one command to make a freshly-cloned checkout runnable.
#
#   ./setup
#
# Creates .venv, installs pinned deps, downloads the Parakeet speech model and
# pre-pulls the on-device correction LLM, then prints the macOS permissions you
# must grant. After it finishes, run ./hovor-it.
#
# macOS, Apple Silicon, Python 3.12.
set -euo pipefail
cd "$(dirname "$0")"

PY=.venv/bin/python
PARAKEET_DIR="models/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8"
PARAKEET_TARBALL="sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8.tar.bz2"
PARAKEET_URL="https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/${PARAKEET_TARBALL}"
LLM_MODEL="mlx-community/Llama-3.2-1B-Instruct-4bit"

echo "==> 1/5  Python venv + pinned dependencies"
if [ ! -x "$PY" ]; then
  PYBIN="$(command -v python3.12 || command -v python3)"
  echo "    creating .venv with $PYBIN"
  "$PYBIN" -m venv .venv
fi
"$PY" -m pip install --upgrade pip >/dev/null
"$PY" -m pip install -r requirements.txt

echo ""
echo "==> 2/5  Parakeet speech model"
if [ -f "$PARAKEET_DIR/encoder.int8.onnx" ] && [ -f "$PARAKEET_DIR/tokens.txt" ]; then
  echo "    already present at $PARAKEET_DIR — skipping download"
else
  mkdir -p models
  echo "    downloading $PARAKEET_TARBALL (~480 MB) ..."
  curl -L --fail -o "models/$PARAKEET_TARBALL" "$PARAKEET_URL"
  echo "    extracting ..."
  tar -xjf "models/$PARAKEET_TARBALL" -C models
  rm -f "models/$PARAKEET_TARBALL"
fi
# Verify the layout find_model_dir() expects.
missing=0
for f in encoder.int8.onnx decoder.int8.onnx joiner.int8.onnx tokens.txt; do
  if [ ! -f "$PARAKEET_DIR/$f" ]; then echo "    [!] missing $PARAKEET_DIR/$f"; missing=1; fi
done
if [ "$missing" -ne 0 ]; then echo "    [!] Parakeet model is incomplete — re-run ./setup"; exit 1; fi
echo "    ok: 3 .onnx files + tokens.txt in $PARAKEET_DIR"

echo ""
echo "==> 3/5  Pre-pull the on-device correction LLM ($LLM_MODEL)"
echo "    (avoids a multi-hundred-MB surprise download on first dictation)"
.venv/bin/hf download "$LLM_MODEL" >/dev/null
echo "    ok"

echo ""
echo "==> 4/5  macOS permissions (grant these to your TERMINAL app, then relaunch it)"
cat <<'PERMS'
    System Settings > Privacy & Security, grant to your terminal app:
      1. Microphone        — to capture your voice
      2. Accessibility     — to type/paste text into the focused app
      3. Input Monitoring  — to detect the double-tap left Command hotkey
    Then QUIT and reopen the terminal so the grants take effect.
PERMS

echo ""
echo "==> 5/5  Import sanity check"
"$PY" -c "import sherpa_onnx, mlx_lm, sounddevice, pynput; print('    ok: core imports succeed')"

echo ""
echo "Done. Now run:  ./hovor-it"
echo "(double-tap the LEFT Command key to start/stop dictation)"
