# Group 3 — captured from dogfood telemetry (correction_pair / user.verdict, 2026-06-20). Distinctive
# non-word mishears of jargon the recognizer drops; the user manually fixed these post-commit.
ugres         => Postgres
postgress     => Postgres

# Group 4 — "VS Code" the editor. Parakeet usually gets it right ("VS Code" x28 in telemetry) but emits
# two distinctive mishears: the letters split as separate tokens ("V S Code"/"V S code", x4) and the
# acronym as one capitalized token ("Vs Code"). Both forms aliased. The "vs code" form is SAFE despite
# "vs"=versus: across the whole dogfood corpus every "vs"+"code" adjacency was the editor (0 versus usage
# — in speech "versus" transcribes as "versus", not "vs"). Verified on Elias's mic (2026-06-21).
v s code      => VS Code
vs code       => VS Code
