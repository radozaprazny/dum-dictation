# global-tech.aliases — curated GLOBAL tech-vocab phrase-alias pack (GLOBAL-VOCAB-PLAN.md G2)
# Format: spoken form => CanonicalForm   (left matched case-insensitively, word-bounded)
# Rule: distinctive MISHEARD jargon only, multi-word-when-spoken. NOT common English words.
# Left side = the form Parakeet emits (verify on the payoff recording, §6/§7). Drop any that the
# recognizer already gets right (the alias would just never fire = dead weight).
#
# Group 1 — VERIFIED on Elias's mic (G0, 2026-06-17): these fire today.
engine x      => nginx
cube control  => kubectl
cube ctl      => kubectl
local host    => localhost

